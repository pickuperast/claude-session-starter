# Authentication (ONE of these is required)
# Option 1: Claude Code OAuth Token (Recommended - run: claude setup-token)
CLAUDE_CODE_OAUTH_TOKEN=sk-ant-aot01-1dqI-your_oauth_token_here

# Option 2: Anthropic API Key (from https://console.anthropic.com)
# ANTHROPIC_API_KEY=sk-ant-api03-your-api-key-here

# Model Configuration
# Default: claude-haiku-4-5-20251001 (fast and cost-effective)
# Other options: claude-3-5-sonnet-20241022, claude-opus-4
MODEL=claude-haiku-4-5-20251001

# Schedule Configuration
# Comma-separated times in HH:MM format (24-hour)
# Example: 07:01,12:01,17:01 (7:01 AM, 12:01 PM, 5:01 PM)
SCHEDULE_TIMES=07:01,12:01,17:01

# Timezone (IANA timezone name)
# Common options:
#   Asia/Karachi (GMT+5)
#   America/New_York (EST/EDT)
#   Europe/London (GMT/BST)
#   America/Los_Angeles (PST/PDT)
#   Asia/Tokyo (JST)
#   UTC (Coordinated Universal Time)
# Full list: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TIMEZONE=Asia/Karachi

# Message to send (optional - leave empty for random math problems)
# Default behavior: Sends random math like "42+73"
# Set this to send a custom message instead
# MESSAGE_PROMPT=Hello! This is a scheduled message.
